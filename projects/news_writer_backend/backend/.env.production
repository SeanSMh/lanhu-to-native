# ================ 生产环境 .env ================
# 使用方法：服务器上解压后执行 `cp .env.production .env`
# 然后按下面的 [必改] 标记修改必要项。

# 应用
APP_ENV=prod
APP_PORT=8000

# 数据库 / Redis（容器间通信，用 compose service 名做 hostname）
DB_URL=postgresql+asyncpg://news_writer:news_writer@postgres:5432/news_writer
REDIS_URL=redis://redis:6379/0

# 鉴权（首次启动创建单用户用的 token；生产建议用 32+ 字节随机串）
AUTH_INITIAL_API_TOKEN=bril-1332565823a

# LLM
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-e6ba127cf5d1499c8a8ea34d5555fe1c
LLM_MODEL=deepseek-v4-pro

# Embedding
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=sk-zuwhmuqfrahutxjqyhpodquepctefofucwhzkhpcrbuzvpsd
EMBEDDING_MODEL=BAAI/bge-m3

# 对象存储（容器间用 service 名 minio；对外访问用公网地址）
STORAGE_TYPE=minio
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=news-writer

# [必改] 浏览器/App 访问图片的公网前缀。把 YOUR_DOMAIN_OR_IP 换成你的域名或服务器公网 IP
# 例：http://api.example.com:9000/news-writer  或  http://47.x.x.x:9000/news-writer
STORAGE_PUBLIC_BASE=http://YOUR_DOMAIN_OR_IP:9000/news-writer
STORAGE_LOCAL_DIR=./storage

# 搜图（可选，空则 /images/search /images/recommend 会失败，但不阻塞启动）
IMAGE_SEARCH_API_KEY=

# 测试开关（生产保持 false）
FAKE_LLM=false
