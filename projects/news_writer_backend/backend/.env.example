# 应用
APP_ENV=dev
APP_PORT=8000

# 数据库 / Redis
DB_URL=postgresql+asyncpg://news_writer:news_writer@localhost:5432/news_writer
REDIS_URL=redis://localhost:6379/0

# 鉴权（首次启动根据该 token 自动创建单用户）
AUTH_INITIAL_API_TOKEN=change-me-on-first-run

# LLM（OpenAI 兼容）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=deepseek-chat

# Embedding
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_MODEL=BAAI/bge-m3

# 对象存储
STORAGE_TYPE=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=news-writer
STORAGE_PUBLIC_BASE=http://localhost:9000/news-writer
STORAGE_LOCAL_DIR=./storage

# 搜图
IMAGE_SEARCH_API_KEY=

# 测试
FAKE_LLM=false
